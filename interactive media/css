/*body*/
body {
    font-family: Arial, Helvetica, sans-serif;
    background-color: #f4f4f4;
    margin: 0;
}

/*header*/
header {
    background-color: darkgreen;
    color: whitesmoke;
    text-align: center;
    padding: 20px;
}

/*nav bar*/
nav {
    margin-top: 10px;
}

nav a {
    color: whitesmoke;
    margin: 10px;
    font-weight: bold;
}

nav a:hover {
    color: gold;
}

/*hero section*/
.hero {
    background-color: #2e8b57;
    color: whitesmoke;
    text-align: centre;
    padding: 50px;
}

/*buttons*/
.button {
    background-color: gold;
    color: black;
    padding: 10px 20px;
    border-radius: 5px;
    display: inline-block;
    margin: 10px;
}

.button:hover {
    background-color: orange;
}

/*sections*/
section {
    background-color:whitesmoke;
    margin: 20px;
    padding: 20px;
    border-radius: 10px;
}

/*headings*/
h2 {
    color: darkgreen;
}

/*prayer table*/
table {
    width: 100%;
    border-collapse: collapse;
}

table, th, td {
    border: 1px solid black;
}

th {
    background-color: darkgreen;
    color: whitesmoke;
}

th,td {
    padding: 10px;
    text-align: center;
}

/*lists*/
ul {
    padding-left: 20px;
}

/*images*/
img {
    display: block;
    margin: auto;
    max-width: 100%;
    border-radius: 10px;
}

/*forms*/
form {
    width: 60%;
    margin: auto;
}

input,
textarea {
    width: 100%;
    padding: 10px;
    margin-top: 5px;
    margin-bottom: 15px;
}

input[type="submit"] {
    background-color: darkgreen;
    color: whitesmoke;
    border: none;
    cursor: pointer;
}

input[type="submit"]:hover{
    background-color: green;
}

/*footer*/
footer {
    background-color: darkgreen;
    color: whitesmoke;
    text-align: center;
    padding: 20px;
    margin-top: 20px;
}

/*mobile view*/
@media (max-width: 768px) {
    nav a {
        display: block;
        margin: 10px 0;
    }
    form {
        width: 90%;
    }
    .hero {
        padding: 30px;
    }
}