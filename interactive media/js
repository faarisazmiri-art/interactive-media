/*booking true/false*/
function validateBooking() {
    let name = document.getElementById("name").value;
    let email = document.getElementById("email").value;

    if (name == "" || email == "") {
        alert("Please complete all the fields.");
        return false;
    }
    alert("Your booking has been submitted!");
    return true;
}

/*contact form true/false*/
function validateContact() {
    if (event) {
        event.preventDefault();
    }

    let name = document.getElementById("contactName").value;
    let email = document.getElementById("contactEmail").value;
    let message = document.getElementById("message").value;

    if (name == "" || email == "" || message == "") {
        alert("Please complete all the fields.");
        return false;
    }
    alert("Your message has been sent!");
    return true;
}

/*feedback form true/false*/
function validateFeedback() {
    let name = document.getElementById("feedbackName").value;
    let comment = document.getElementById("comment").value;

    if (name == "" || comment == "") {
        alert("Please complete all the fields.");
        return false;
    }
    alert("Thank you for your feedback!");
    return true;
}

/*accessibility*/
function readPage() {
    let speech = new SpeechSynthesisUtterance(document.body.innerText);
    speech.lang = "en-AU";
    speech.rate = 0.9
    speech.pitch = 1;
    speechSynthesis.speak(speech);
}

function stopReading() {
    speechSynthesis.cancel();
}

/**slideshow for gallery page**/
let slideIndex = 1;
showSlides(slideIndex);

function plusSlides(n) {
    showSlides(slideIndex += n);
}

function showSlides(n) {
    let i;
    let slides = document.getElementsByClassName("mySlides");
    if (slides.length === 0) return;
    if (n > slides.length) {slideIndex = 1}
    if (n < 1) {slideIndex = slides.length}
    for (i = 0; i < slides.length; i++) {
        slides[i].style.display = "none";
    }
    slides[slideIndex-1].style.display = "block";
}

/**auto slide evrry 4s**/
setInterval(function() {
    plusSlides(1);
}, 7000);

/**dropdown filter script**/
function filterSelection(c) {
    let x = document.getElementsByClassName("filterDiv");
    if (c === "all") c="";
    for (let i = 0; i < x.length; i++) {
        x[i].style.display = "none";
        if (x[i].className.indexOf(c) > -1) {
            x[i].style.display = "block";
        }
    }
}

/**modal light box script**/
function openModal (imgElement) {
    let modal = document.getElementById("imageModal");
    let modalImg = document.getElementById("imgModalTarget");
    let captionText = document.getElementById("modalCaption");

    if (modal && modalImg) {
        modal.style.display = "block";
        modalImg.src = imgElement.src;
        if (captionText) {
            captionText.innerHTML = imgElement.alt || "";
        }
    }
}

function closeModal() {
    let modal = document.getElementById("imageModal");
    if (modal) {
        modal.style.display = "none";
    }
}

/**close when clicking outside pic**/
window.onclick = function(event) {
    let modal = document.getElementById("imageModal");
    if (event.target === modal) {
        modal.style.display = "none";
    }
}